{
  "name": "@orwellg/cli",
  "version": "0.2.0",
  "description": "A CLI tool to help you to work with Watcher-based alerts",
  "type": "module",
  "bin": {
    "orwell": "./bin/orwell.ts"
  },
  "files": [
    "bin/",
    "lib/",
    "dsl/",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/orwell.ts",
    "test": "node --test '**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "elastic",
    "watchers",
    "open telemetry",
    "alerts",
    "observability"
  ],
  "author": "Edy Silva <edigleyssonsilva@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.8.4",
    "commander": "^12.1.0",
    "marked": "^15.0.8",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.5",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
